# --- LLM backend (model id agnostic; override per-env) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Kill switch (NH APIM-killswitch equivalent) ---
# When set to "1", every LLM call returns a canned stub without hitting OpenAI.
LLM_KILL_SWITCH=0

# --- Paths ---
STOCK_AGENT_DATA_DIR=./data
STOCK_AGENT_SEED_DIR=./seed

# --- Serving ---
AGENT_INT_PORT=8001
SOURCE_EXT_PORT=8002

# --- Tiering ---
EAGER_TOP_N=5
