# --- LLM backend (model id agnostic; override per-env) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Kill switch (NH APIM-killswitch equivalent) ---
# When set to "1", every LLM call returns a canned stub without hitting OpenAI.
LLM_KILL_SWITCH=0

# --- Paths ---
STOCK_AGENT_DATA_DIR=./data
STOCK_AGENT_SEED_DIR=./seed

# --- Serving ---
AGENT_INT_PORT=8001
SOURCE_EXT_PORT=8002

# --- Tiering ---
EAGER_TOP_N=5

# --- Wiki 편집 (admin) — /wiki/admin + /api/v1/admin/* ---
# 비밀번호를 설정하면 편집 UI 가 활성화됨. 미설정시 admin 라우트 전체가 503 응답.
# WIKI_EDIT_PASSWORD=
# 세션 토큰 TTL (초). 기본 28800 = 8시간.
# WIKI_EDIT_SESSION_TTL=28800
